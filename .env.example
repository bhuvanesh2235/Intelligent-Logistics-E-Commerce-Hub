# ══════════════════════════════════════════════════════════════
# .env.example — Intelligent Logistics & E-Commerce Hub
# Copy to .env and fill in your values before running
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=your_secure_db_password
DB_USERNAME=root

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your_256bit_jwt_secret_key_here
JWT_EXPIRATION_MS=86400000

# ── Kaggle (for ML pipeline maintenance) ─────────────────────
KAGGLE_API_TOKEN=your_kaggle_api_token
KAGGLE_USERNAME=your_kaggle_username

# ── Flask ML APIs ─────────────────────────────────────────────
FORECAST_API_URL=http://localhost:5001
DAMAGE_API_URL=http://localhost:5002

# ── Frontend (Vite) ───────────────────────────────────────────
VITE_FORECAST_API_URL=http://localhost:5001
VITE_DAMAGE_API_URL=http://localhost:5002
VITE_API_BASE_URL=http://localhost:8080

# ── Docker ────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=logistics-hub
